<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h1 class="mb-1"><%= event.event_name %></h1>
    <% if (event.teams.length > 0) { %>
      <div class="text-muted"><%= event.teams.join(' vs ') %></div>
    <% } %>
  </div>
  <div class="d-flex gap-2">
    <a href="/manual-ledger/reports/consolidated" class="btn btn-outline-primary">Consolidated Report</a>
    <a href="/manual-ledger/events/<%= event.id %>/entries/create" class="btn btn-primary">Add Session Entry</a>
    <a href="/manual-ledger" class="btn btn-secondary">Back</a>
  </div>
</div>

<%
  const teams = event.teams || [];
  const sessionOvers = [6, 10, 15, 20];
%>
<% if (teams.length >= 2) { %>
<div class="card mb-4">
  <div class="card-header"><strong>Quick Add Session Entry</strong></div>
  <div class="card-body py-2">
    <% teams.forEach(function(team, idx) { %>
      <div class="mb-1">
        <span class="small fw-semibold me-2"><%= team %> (<%= idx === 0 ? '1st' : '2nd' %> inn):</span>
        <% sessionOvers.forEach(function(ov) { %>
          <a href="/manual-ledger/events/<%= event.id %>/entries/create?marketType=session&marketName=<%= encodeURIComponent(ov + ' Over ' + team) %>"
             class="btn btn-sm btn-outline-info me-1 mb-1"><%= ov %> Ov</a>
        <% }) %>
      </div>
    <% }) %>
  </div>
</div>
<% } %>

<% if (event.note) { %>
  <div class="alert alert-info"><%= event.note %></div>
<% } %>

<div class="row g-3 mb-4">
  <div class="col-md-3">
    <div class="card h-100">
      <div class="card-body">
        <div class="text-muted small">Status</div>
        <div class="fs-4 fw-semibold text-capitalize"><%= summary.status %></div>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card h-100">
      <div class="card-body">
        <div class="text-muted small">Entries</div>
        <div class="fs-4 fw-semibold"><%= summary.entry_count %></div>
        <div class="small text-muted"><%= summary.open_entry_count %> open / <%= summary.settled_entry_count %> settled</div>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card h-100">
      <div class="card-body">
        <div class="text-muted small">Realized P&amp;L</div>
        <div class="fs-4 fw-semibold <%= summary.realized_profit_or_loss >= 0 ? 'text-success' : 'text-danger' %>">
          ₹<%= summary.realized_profit_or_loss.toFixed(2) %>
        </div>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card h-100">
      <div class="card-body">
        <div class="text-muted small">Open Risk / Profit</div>
        <div class="fw-semibold">Risk: ₹<%= summary.open_risk.toFixed(2) %></div>
        <div class="small text-muted">Potential profit: ₹<%= summary.open_potential_profit.toFixed(2) %></div>
      </div>
    </div>
  </div>
</div>

<%
  // Gather open session markets for bulk settlement
  const openSessionMarkets = {};
  entries.forEach(function(e) {
    if (e.market_type === 'session' && e.status === 'open') {
      if (!openSessionMarkets[e.market_name]) {
        openSessionMarkets[e.market_name] = 0;
      }
      openSessionMarkets[e.market_name]++;
    }
  });
  const sessionMarketNames = Object.keys(openSessionMarkets);
%>

<% if (sessionMarketNames.length > 0) { %>
<div class="card mb-4">
  <div class="card-header"><strong>Settle Sessions by Score</strong></div>
  <div class="card-body">
    <div class="row g-3">
      <% sessionMarketNames.forEach(function(mkt) { %>
        <div class="col-md-6 col-lg-4">
          <form action="/manual-ledger/events/<%= event.id %>/settle-sessions" method="POST" class="d-flex align-items-end gap-2">
            <input type="hidden" name="marketName" value="<%= mkt %>">
            <div class="flex-grow-1">
              <label class="form-label small mb-1"><%= mkt %> <span class="badge bg-secondary"><%= openSessionMarkets[mkt] %></span></label>
              <input type="number" class="form-control form-control-sm" name="actualScore" min="0" step="1" required placeholder="Score">
            </div>
            <button type="submit" class="btn btn-sm btn-success" onclick="return confirm('Settle all open entries for <%= mkt %> with this score?')">Settle</button>
          </form>
        </div>
      <% }) %>
    </div>
  </div>
</div>
<% } %>

<div class="card mb-4">
  <div class="card-header d-flex justify-content-between align-items-center">
    <h3 class="h5 mb-0">Offline Entries</h3>
    <form action="/manual-ledger/events/<%= event.id %>/delete" method="POST" onsubmit="return confirm('Delete this offline event and all its entries?')">
      <button type="submit" class="btn btn-sm btn-outline-danger">Delete Event</button>
    </form>
  </div>
  <div class="card-body p-0">
    <% if (entries.length === 0) { %>
      <div class="p-4 text-muted">No offline bets added yet.</div>
    <% } else { %>
      <div class="table-responsive">
        <table class="table table-striped mb-0">
          <thead>
            <tr>
              <th>Customer</th>
              <th>Market</th>
              <th>Selection / Line</th>
              <th>Side</th>
              <th>Stake</th>
              <th>Price / Rate</th>
              <th>Potential</th>
              <th>Risk</th>
              <th>Status</th>
              <th>Realized P&amp;L</th>
              <th>Created</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% entries.forEach((entry) => { %>
              <tr>
                <td>
                  <div class="fw-semibold"><%= entry.customer_name %></div>
                  <% if (entry.note) { %>
                    <div class="small text-muted"><%= entry.note %></div>
                  <% } %>
                </td>
                <td>
                  <div><%= entry.market_name %></div>
                  <div class="small text-muted text-capitalize"><%= entry.market_type %></div>
                </td>
                <td><%= entry.selection %></td>
                <td>
                  <span class="badge bg-<%= entry.bet_type === 'back' ? 'primary' : 'danger' %> text-uppercase">
                    <%= entry.market_type === 'session' ? (entry.bet_type === 'back' ? 'YES' : 'NO') : entry.bet_type %>
                  </span>
                </td>
                <td>₹<%= entry.stake.toFixed(2) %></td>
                <td><%= entry.price.toFixed(2) %><%= entry.market_type === 'session' ? '' : '' %></td>
                <td class="text-success">₹<%= entry.potential_profit.toFixed(2) %></td>
                <td class="text-danger">₹<%= entry.potential_risk.toFixed(2) %></td>
                <td>
                  <span class="badge bg-<%= entry.status === 'open' ? 'secondary' : (entry.status === 'won' ? 'success' : entry.status === 'lost' ? 'danger' : 'warning text-dark') %>">
                    <%= entry.status %>
                  </span>
                </td>
                <td class="<%= (entry.realized_profit_or_loss || 0) >= 0 ? 'text-success' : 'text-danger' %>">
                  <%= entry.realized_profit_or_loss !== undefined ? `₹${entry.realized_profit_or_loss.toFixed(2)}` : '—' %>
                </td>
                <td><%= new Date(entry.created_at).toLocaleString() %></td>
                <td class="text-end">
                  <div class="d-flex gap-1 justify-content-end">
                    <% if (entry.status === 'open') { %>
                      <a href="/manual-ledger/events/<%= event.id %>/entries/<%= entry.id %>/edit" class="btn btn-sm btn-outline-primary">Edit</a>
                    <% } %>
                    <a href="/manual-ledger/events/<%= event.id %>/entries/<%= entry.id %>/settle" class="btn btn-sm btn-outline-success">Settle</a>
                    <form action="/manual-ledger/events/<%= event.id %>/entries/<%= entry.id %>/delete" method="POST" onsubmit="return confirm('Delete this offline entry?')">
                      <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
</div>
