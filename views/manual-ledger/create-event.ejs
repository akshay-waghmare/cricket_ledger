<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="mb-0">Create Session Event</h1>
  <a href="/manual-ledger" class="btn btn-secondary">Back</a>
</div>

<div class="card">
  <div class="card-body">
    <form action="/manual-ledger/events" method="POST">
      <div class="mb-3">
        <label for="eventName" class="form-label">Event Name</label>
        <input
          type="text"
          class="form-control"
          id="eventName"
          name="eventName"
          required
          value="<%= formData?.eventName || '' %>"
          placeholder="RCB vs CSK - Session Ledger"
        >
      </div>

      <div class="mb-3">
        <label for="teams" class="form-label">Teams (optional)</label>
        <input
          type="text"
          class="form-control"
          id="teams"
          name="teams"
          value="<%= formData?.teams || '' %>"
          placeholder="Royal Challengers Bengaluru, Chennai Super Kings"
        >
        <div class="form-text">Comma-separated. These power the quick 6/10/15/20 over session presets.</div>
      </div>

      <div class="mb-3">
        <label for="note" class="form-label">Notes (optional)</label>
        <textarea class="form-control" id="note" name="note" rows="3" placeholder="Any offline context you want to keep"><%= formData?.note || '' %></textarea>
      </div>

      <div class="d-flex justify-content-end gap-2">
        <a href="/manual-ledger" class="btn btn-light">Cancel</a>
        <button type="submit" class="btn btn-primary">Create Event</button>
      </div>
    </form>
  </div>
</div>
