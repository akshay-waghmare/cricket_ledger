<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h1 class="mb-1">Consolidated Manual P&amp;L</h1>
    <p class="text-muted mb-0">Roll-up across all offline events you track manually.</p>
  </div>
  <div class="d-flex gap-2">
    <a href="/admin/manual-ledger" class="btn btn-secondary">Back to Ledger</a>
    <a href="/admin/manual-ledger/events/create" class="btn btn-primary">Create Offline Event</a>
  </div>
</div>

<div class="row g-3 mb-4">
  <div class="col-md-4">
    <div class="card h-100">
      <div class="card-body">
        <div class="text-muted small">Realized P&amp;L</div>
        <div class="fs-3 fw-semibold <%= overview.totals.realized_profit_or_loss >= 0 ? 'text-success' : 'text-danger' %>">
          ₹<%= overview.totals.realized_profit_or_loss.toFixed(2) %>
        </div>
      </div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card h-100">
      <div class="card-body">
        <div class="text-muted small">Open Risk</div>
        <div class="fs-3 fw-semibold text-danger">₹<%= overview.totals.open_risk.toFixed(2) %></div>
      </div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card h-100">
      <div class="card-body">
        <div class="text-muted small">Open Potential Profit</div>
        <div class="fs-3 fw-semibold text-success">₹<%= overview.totals.open_potential_profit.toFixed(2) %></div>
      </div>
    </div>
  </div>
</div>

<div class="card">
  <div class="card-header">
    <h3 class="h5 mb-0">Event Breakdown</h3>
  </div>
  <div class="card-body p-0">
    <% if (overview.events.length === 0) { %>
      <div class="p-4 text-muted">No offline events to report yet.</div>
    <% } else { %>
      <div class="table-responsive">
        <table class="table table-striped mb-0">
          <thead>
            <tr>
              <th>Event</th>
              <th>Entries</th>
              <th>Realized P&amp;L</th>
              <th>Open Risk</th>
              <th>Potential Profit</th>
              <th>Last Activity</th>
            </tr>
          </thead>
          <tbody>
            <% overview.events.forEach((event) => { %>
              <tr>
                <td>
                  <div class="fw-semibold"><a href="/admin/manual-ledger/events/<%= event.event_id %>"><%= event.event_name %></a></div>
                  <% if (event.teams.length > 0) { %>
                    <div class="small text-muted"><%= event.teams.join(' vs ') %></div>
                  <% } %>
                </td>
                <td><%= event.entry_count %> total / <%= event.open_entry_count %> open</td>
                <td class="<%= event.realized_profit_or_loss >= 0 ? 'text-success' : 'text-danger' %>">
                  ₹<%= event.realized_profit_or_loss.toFixed(2) %>
                </td>
                <td>₹<%= event.open_risk.toFixed(2) %></td>
                <td>₹<%= event.open_potential_profit.toFixed(2) %></td>
                <td><%= new Date(event.updated_at).toLocaleString() %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
</div>
