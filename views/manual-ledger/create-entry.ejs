<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h1 class="mb-1">Add Offline Entry</h1>
    <div class="text-muted"><%= event.event_name %></div>
  </div>
  <a href="/admin/manual-ledger/events/<%= event.id %>" class="btn btn-secondary">Back</a>
</div>

<%
  // Build team list for session preset buttons
  const teams = event.teams || [];
  const sessionOvers = [6, 10, 15, 20];
%>

<% if (teams.length >= 2) { %>
<div class="card mb-3">
  <div class="card-header"><strong>Quick Session Presets (T20)</strong></div>
  <div class="card-body">
    <% teams.forEach(function(team, idx) { %>
      <div class="mb-2">
        <span class="fw-semibold me-2"><%= team %> (<%= idx === 0 ? '1st' : '2nd' %> inn):</span>
        <% sessionOvers.forEach(function(ov) { %>
          <button type="button" class="btn btn-sm btn-outline-info me-1 mb-1 session-preset-btn"
            data-market-type="session"
            data-market-name="<%= ov %> Over <%= team %>"
            data-selection="Over"
          ><%= ov %> Ov <%= team %></button>
        <% }) %>
      </div>
    <% }) %>
    <div class="small text-muted mt-1">Click a preset to auto-fill market fields. Then set customer, side, stake, rate &amp; submit.</div>
  </div>
</div>
<% } %>

<div class="card">
  <div class="card-body">
    <form action="/admin/manual-ledger/events/<%= event.id %>/entries" method="POST">
      <div class="row g-3">
        <div class="col-md-6">
          <label for="customerName" class="form-label">Offline Customer / Counterparty</label>
          <input type="text" class="form-control" id="customerName" name="customerName" required value="<%= formData?.customerName || '' %>">
        </div>
        <div class="col-md-6">
          <label for="marketType" class="form-label">Market Type</label>
          <select class="form-select" id="marketType" name="marketType" required>
            <option value="match" <%= !formData || formData.marketType === 'match' ? 'selected' : '' %>>Match</option>
            <option value="session" <%= formData?.marketType === 'session' ? 'selected' : '' %>>Session</option>
          </select>
        </div>
        <div class="col-md-6">
          <label for="marketName" class="form-label">Market Name</label>
          <input type="text" class="form-control" id="marketName" name="marketName" required value="<%= formData?.marketName || '' %>" placeholder="Match Odds / 20 Over CSK">
        </div>
        <div class="col-md-6">
          <label for="selection" class="form-label" id="selectionLabel">Selection</label>
          <input type="text" class="form-control" id="selection" name="selection" required value="<%= formData?.selection || '' %>" placeholder="CSK / Over / Under">
          <div class="form-text" id="selectionHelp" style="display:none">The line number the bet is on (e.g. 35, 42). Used for auto-settlement.</div>
        </div>
        <div class="col-md-6">
          <label for="betType" class="form-label">Side</label>
          <select class="form-select" id="betType" name="betType" required>
            <option value="back" <%= !formData || formData.betType === 'back' ? 'selected' : '' %>>Back (YES)</option>
            <option value="lay" <%= formData?.betType === 'lay' ? 'selected' : '' %>>Lay (NO)</option>
          </select>
        </div>
        <div class="col-md-3">
          <label for="stake" class="form-label">Stake</label>
          <input type="number" class="form-control" id="stake" name="stake" min="0.01" step="0.01" required value="<%= formData?.stake || '' %>">
        </div>
        <div class="col-md-3">
          <label for="price" class="form-label" id="priceLabel">Price / Rate</label>
          <input type="number" class="form-control" id="price" name="price" min="0.01" step="0.01" required value="<%= formData?.price || '' %>">
        </div>
        <div class="col-12">
          <label for="note" class="form-label">Note (optional)</label>
          <textarea class="form-control" id="note" name="note" rows="2" placeholder="Any offline note"><%= formData?.note || '' %></textarea>
        </div>
      </div>

      <div class="alert alert-secondary mt-3 mb-0" id="calcHelp">
        <strong>Calculation rule:</strong>
        <span id="calcMatchHelp">Match: back profit = stake × (price − 1), lay risk = stake × (price − 1).</span>
        <span id="calcSessionHelp" style="display:none">Session: back profit = stake × rate / 100, lay risk = stake × rate / 100.</span>
      </div>

      <div class="d-flex justify-content-end gap-2 mt-3">
        <a href="/admin/manual-ledger/events/<%= event.id %>" class="btn btn-light">Cancel</a>
        <button type="submit" class="btn btn-primary">Add Entry</button>
      </div>
    </form>
  </div>
</div>

<script>
  // Session preset buttons
  document.querySelectorAll('.session-preset-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      document.getElementById('marketType').value = this.dataset.marketType;
      document.getElementById('marketName').value = this.dataset.marketName;
      document.getElementById('selection').value = '';
      toggleCalcHelp();
      // Focus the selection (line) input so user enters the line
      document.getElementById('selection').focus();
      // Highlight filled fields briefly
      ['marketType', 'marketName'].forEach(function(id) {
        var el = document.getElementById(id);
        el.classList.add('border-info');
        setTimeout(function() { el.classList.remove('border-info'); }, 1200);
      });
    });
  });

  // Toggle help text, labels, and placeholders based on market type
  var marketTypeSelect = document.getElementById('marketType');
  function toggleCalcHelp() {
    var isSession = marketTypeSelect.value === 'session';
    document.getElementById('calcMatchHelp').style.display = isSession ? 'none' : '';
    document.getElementById('calcSessionHelp').style.display = isSession ? '' : 'none';
    document.getElementById('priceLabel').textContent = isSession ? 'Rate (e.g. 90)' : 'Price (decimal odds)';
    document.getElementById('selectionLabel').textContent = isSession ? 'Line (runs)' : 'Selection';
    document.getElementById('selection').placeholder = isSession ? 'e.g. 35, 42, 155' : 'CSK / RCB / Draw';
    document.getElementById('selectionHelp').style.display = isSession ? '' : 'none';
  }
  marketTypeSelect.addEventListener('change', toggleCalcHelp);
  toggleCalcHelp();
</script>
