<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h1 class="mb-1">Settle Offline Entry</h1>
    <div class="text-muted"><%= event.event_name %></div>
  </div>
  <a href="/admin/manual-ledger/events/<%= event.id %>" class="btn btn-secondary">Back</a>
</div>

<div class="card mb-4">
  <div class="card-body">
    <div class="row g-3">
      <div class="col-md-6"><strong>Customer:</strong> <%= entry.customer_name %></div>
      <div class="col-md-6"><strong>Market:</strong> <%= entry.market_name %> (<%= entry.market_type %>)</div>
      <div class="col-md-6"><strong>Selection:</strong> <%= entry.selection %></div>
      <div class="col-md-6"><strong>Side:</strong> <%= entry.bet_type %></div>
      <div class="col-md-4"><strong>Stake:</strong> ₹<%= entry.stake.toFixed(2) %></div>
      <div class="col-md-4"><strong>Price:</strong> <%= entry.price.toFixed(2) %></div>
      <div class="col-md-4"><strong>Status:</strong> <%= entry.status %></div>
      <div class="col-md-6 text-success"><strong>If won:</strong> ₹<%= entry.potential_profit.toFixed(2) %></div>
      <div class="col-md-6 text-danger"><strong>If lost:</strong> -₹<%= entry.potential_risk.toFixed(2) %></div>
    </div>
  </div>
</div>

<div class="card">
  <div class="card-body">
    <form action="/admin/manual-ledger/events/<%= event.id %>/entries/<%= entry.id %>/settle" method="POST">
      <label class="form-label">Settlement Result</label>
      <div class="form-check">
        <input class="form-check-input" type="radio" name="status" id="statusWon" value="won" <%= entry.status === 'won' ? 'checked' : '' %>>
        <label class="form-check-label" for="statusWon">Won (+₹<%= entry.potential_profit.toFixed(2) %>)</label>
      </div>
      <div class="form-check">
        <input class="form-check-input" type="radio" name="status" id="statusLost" value="lost" <%= entry.status === 'lost' ? 'checked' : '' %>>
        <label class="form-check-label" for="statusLost">Lost (-₹<%= entry.potential_risk.toFixed(2) %>)</label>
      </div>
      <div class="form-check mb-3">
        <input class="form-check-input" type="radio" name="status" id="statusVoid" value="void" <%= entry.status === 'void' ? 'checked' : '' %>>
        <label class="form-check-label" for="statusVoid">Void (₹0.00)</label>
      </div>

      <div class="d-flex justify-content-end gap-2">
        <a href="/admin/manual-ledger/events/<%= event.id %>" class="btn btn-light">Cancel</a>
        <button type="submit" class="btn btn-success">Save Settlement</button>
      </div>
    </form>
  </div>
</div>
