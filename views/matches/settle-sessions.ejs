<%- include('../partials/header') %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h1>Settle Sessions: <%= match.teams.join(' vs ') %></h1>
  <div>
    <a href="/matches/<%= match.match_id %>" class="btn btn-secondary">Back to Match</a>
  </div>
</div>

<div class="alert alert-warning">
  Enter the actual score for each session market. The system will settle all open YES/NO entries for that market automatically.
</div>

<% const marketNames = Object.keys(openSessionMarkets || {}); %>

<% if (marketNames.length === 0) { %>
  <div class="alert alert-info">
    No open session entries found for this match.
  </div>
<% } else { %>
  <div class="row g-3 mb-4">
    <% marketNames.forEach((marketName) => { %>
      <div class="col-md-6 col-lg-4">
        <div class="card h-100">
          <div class="card-body">
            <form action="/matches/<%= match.match_id %>/settle-sessions" method="POST">
              <input type="hidden" name="marketName" value="<%= marketName %>">
              <div class="mb-3">
                <label class="form-label"><strong><%= marketName %></strong></label>
                <div class="small text-muted"><%= openSessionMarkets[marketName] %> open entries</div>
              </div>
              <div class="mb-3">
                <label class="form-label">Actual Score</label>
                <input type="number" class="form-control" name="actualScore" min="0" step="1" required placeholder="e.g. 42">
              </div>
              <button type="submit" class="btn btn-success w-100">Settle This Market</button>
            </form>
          </div>
        </div>
      </div>
    <% }) %>
  </div>
<% } %>

<div class="card">
  <div class="card-header bg-info text-white">
    <h5 class="mb-0">Session Entries</h5>
  </div>
  <div class="card-body p-0">
    <% if (sessionEntries && sessionEntries.length > 0) { %>
      <div class="table-responsive">
        <table class="table table-striped mb-0">
          <thead>
            <tr>
              <th>Customer</th>
              <th>Market</th>
              <th>Line</th>
              <th>Side</th>
              <th>Stake</th>
              <th>Rate</th>
              <th>Status</th>
              <th>P/L</th>
            </tr>
          </thead>
          <tbody>
            <% sessionEntries.forEach((entry) => { %>
              <tr>
                <td><%= entry.customer_name %></td>
                <td><%= entry.market_name %></td>
                <td><%= entry.selection %></td>
                <td><%= entry.bet_type === 'back' ? 'YES' : 'NO' %></td>
                <td><%= entry.stake.toFixed(2) %></td>
                <td><%= entry.price.toFixed(2) %></td>
                <td><%= entry.status %></td>
                <td><%= entry.realized_profit_or_loss !== undefined ? entry.realized_profit_or_loss.toFixed(2) : '—' %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <div class="p-3 text-muted">No session entries yet.</div>
    <% } %>
  </div>
</div>

<%- include('../partials/footer') %>
