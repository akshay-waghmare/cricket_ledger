<%- include('../partials/header') %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h1>Place a Bet</h1>
  <a href="/matches/<%= match.match_id %>" class="btn btn-secondary">Back to Match</a>
</div>

<div class="card">
  <div class="card-header bg-primary text-white">
    <h5 class="mb-0">Bet Details - <%= match.teams.join(' vs ') %></h5>
  </div>
  <div class="card-body">
    <form action="/bets" method="POST">
      <input type="hidden" name="matchId" value="<%= match.match_id %>">
      
      <div class="mb-3">
        <label for="userId" class="form-label">User</label>
        <select class="form-select" id="userId" name="userId" required>
          <option value="">-- Select user --</option>
          <% users.forEach(user => { %>
            <option value="<%= user.id %>" <%= (formData && formData.userId === user.id) ? 'selected' : '' %>>
              <%= user.id %> (Balance: <%= user.balance.toFixed(2) %>)
            </option>
          <% }); %>
        </select>
      </div>
      
      <div class="mb-3">
        <label class="form-label">Bet Type</label>
        <div class="form-check">
          <input class="form-check-input" type="radio" name="betType" id="betTypeBack" value="back" 
            <%= (!formData || formData.betType === 'back') ? 'checked' : '' %>>
          <label class="form-check-label" for="betTypeBack">
            Back (Bet on a team to win)
          </label>
        </div>
        <div class="form-check">
          <input class="form-check-input" type="radio" name="betType" id="betTypeLay" value="lay"
            <%= (formData && formData.betType === 'lay') ? 'checked' : '' %>>
          <label class="form-check-label" for="betTypeLay">
            Lay (Bet against a team winning)
          </label>
        </div>
      </div>
      
      <div class="mb-3">
        <label for="target" class="form-label">Target Team</label>
        <select class="form-select" id="target" name="target" required>
          <option value="">-- Select team --</option>
          <% match.teams.forEach(team => { %>
            <option value="<%= team %>" <%= (formData && formData.target === team) ? 'selected' : '' %>>
              <%= team %>
            </option>
          <% }); %>
        </select>
      </div>
      
      <div class="row">
        <div class="col-md-6 mb-3">
          <label for="stake" class="form-label">Stake</label>
          <div class="input-group">
            <span class="input-group-text">$</span>
            <input type="number" class="form-control" id="stake" name="stake" min="1" step="any" required
              value="<%= formData ? formData.stake : '100' %>">
          </div>
        </div>
        
        <div class="col-md-6 mb-3">
        <label for="odds" class="form-label">Odds</label>
        <input type="number" class="form-control" id="odds" name="odds" min="1.001" step="0.001" required
            value="<%= formData ? formData.odds : '2.000' %>">
        </div>
      </div>
      
      <div class="d-flex justify-content-between">
        <a href="/matches/<%= match.match_id %>" class="btn btn-secondary">Cancel</a>
        <button type="submit" class="btn btn-primary">Place Bet</button>
      </div>
    </form>
  </div>
</div>

<div class="card mt-4" id="session-entry-card">
  <div class="card-header bg-warning text-dark">
    <h5 class="mb-0">Add Session / Fancy Entry</h5>
  </div>
  <div class="card-body">
    <% const sessionOvers = [6, 10, 15, 20]; %>
    <div class="mb-3">
      <div class="fw-semibold mb-2">Quick session presets</div>
      <% match.teams.forEach((team, idx) => { %>
        <div class="mb-2">
          <span class="me-2"><%= team %> (<%= idx === 0 ? '1st' : '2nd' %> inn):</span>
          <% sessionOvers.forEach((ov) => { %>
            <button
              type="button"
              class="btn btn-sm btn-outline-secondary me-1 mb-1 session-preset-btn"
              data-market-name="<%= ov %> Over <%= team %>"
            >
              <%= ov %> Ov
            </button>
          <% }) %>
        </div>
      <% }) %>
    </div>

    <% if (users && users.length > 0) { %>
      <form action="/matches/<%= match.match_id %>/session-entries" method="POST">
        <input type="hidden" name="redirectTo" value="/bets/create/<%= match.match_id %>#session-entry-card">

        <div class="mb-3">
          <label for="customerUserId" class="form-label">Customer</label>
          <select class="form-select" id="customerUserId" name="customerUserId" required>
            <option value="">-- Select customer --</option>
            <% users.forEach(user => { %>
              <option value="<%= user.id %>"><%= user.id %> (Balance: <%= user.balance.toFixed(2) %>)</option>
            <% }); %>
          </select>
        </div>

        <div class="row">
          <div class="col-md-6 mb-3">
            <label for="marketName" class="form-label">Session Market</label>
            <input type="text" class="form-control" id="marketName" name="marketName" required placeholder="20 Over CSK">
          </div>
          <div class="col-md-6 mb-3">
            <label for="selection" class="form-label">Line (runs)</label>
            <input type="number" class="form-control" id="selection" name="selection" min="0" step="1" required placeholder="e.g. 35">
          </div>
        </div>

        <div class="row">
          <div class="col-md-4 mb-3">
            <label for="sessionBetType" class="form-label">Side</label>
            <select class="form-select" id="sessionBetType" name="betType" required>
              <option value="back">YES / Back</option>
              <option value="lay">NO / Lay</option>
            </select>
          </div>
          <div class="col-md-4 mb-3">
            <label for="sessionStake" class="form-label">Stake</label>
            <input type="number" class="form-control" id="sessionStake" name="stake" min="0.01" step="0.01" required value="100">
          </div>
          <div class="col-md-4 mb-3">
            <label for="sessionPrice" class="form-label">Rate</label>
            <input type="number" class="form-control" id="sessionPrice" name="price" min="0.01" step="0.01" required value="90">
          </div>
        </div>

        <div class="mb-3">
          <label for="sessionNote" class="form-label">Note (optional)</label>
          <input type="text" class="form-control" id="sessionNote" name="note" placeholder="Phone entry, office entry, etc.">
        </div>

        <div class="alert alert-secondary">
          Session / fancy math: YES profit = stake x rate / 100. NO risk = stake x rate / 100.
        </div>

        <div class="d-flex justify-content-between">
          <a href="/matches/<%= match.match_id %>" class="btn btn-secondary">Back to Match</a>
          <button type="submit" class="btn btn-warning">Add Session Entry</button>
        </div>
      </form>
    <% } else { %>
      <div class="alert alert-warning mb-0">
        No customers available. <a href="/users/create">Create a user</a> to add a session/fancy entry.
      </div>
    <% } %>
  </div>
</div>

<script>
  document.querySelectorAll('.session-preset-btn').forEach(function(button) {
    button.addEventListener('click', function() {
      document.getElementById('marketName').value = this.dataset.marketName;
      document.getElementById('selection').focus();
    });
  });
</script>

<%- include('../partials/footer') %>
